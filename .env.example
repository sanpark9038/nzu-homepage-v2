NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SOOP_CLIENT_ID=your_soop_client_id
SOOP_SYNC_SECRET=your_random_sync_secret
SOOP_BROAD_LIST_PAGE_LIMIT=200
SOOP_SYNC_HEARTBEAT_MINUTES=10

# Required in production: SOOP Edge Function revalidates public player cache after DB writes.
SERVING_REVALIDATE_URL=https://your-site.example.com
SERVING_REVALIDATE_SECRET=your_revalidate_secret
# Local-only escape hatch for DB-only smoke tests.
SOOP_SYNC_ALLOW_REVALIDATION_SKIP=false

# Board image uploads use Cloudflare R2 through the server-only API route.
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=your_r2_bucket_name
R2_PUBLIC_BASE_URL=https://your-public-r2-domain.example.com

# Player history artifacts are generated by the ops pipeline and can be served from R2.
# Optional dedicated R2 credentials. If omitted, the generic R2 account/key env above are used.
PLAYER_HISTORY_R2_ACCOUNT_ID=your_cloudflare_account_id
PLAYER_HISTORY_R2_ACCESS_KEY_ID=your_player_history_r2_access_key_id
PLAYER_HISTORY_R2_SECRET_ACCESS_KEY=your_player_history_r2_secret_access_key
PLAYER_HISTORY_R2_BUCKET_NAME=nzu-homepage-data
PLAYER_HISTORY_PUBLIC_BASE_URL=https://your-public-player-history-r2-domain.example.com/player-history
PLAYER_HISTORY_R2_PREFIX=player-history
SUPABASE_MATCH_HISTORY_LIMIT=100
