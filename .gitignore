# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# build logs & dumps
build_err.txt
build_error.log
build_error.txt
*.html
!public/*.html


# temp
.tmp/
/tmp/*
!/tmp/final_clean.json
!/tmp/player_metadata_integrity_report.json
!/tmp/player_metadata_canonical_preview.json
!/tmp/player_metadata.cleaned.json

# pipeline data & warehouse
/data/metadata/players.master.v1.json
/data/warehouse/
*.bak.*

# AI coordination (exclude UI-specific logic instruction files)
MAIN_AI_UI_BRIEFING.md
MAIN_AI_UI_ONLY_INSTRUCTION.md
.planning/
prod-sync.log
